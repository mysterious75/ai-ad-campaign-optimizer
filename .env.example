# LLM API Keys (at least one required)
GEMINI_API_KEY="your-gemini-api-key"
ANTHROPIC_API_KEY="sk-ant-..."

# Model rotation list (comma-separated, tried in order, falls back on failure)
# Supported prefixes: gemini-, gemma-, claude-
LLM_MODELS="gemini-2.5-flash,gemini-2.5-pro,gemini-3.5-flash,claude-sonnet-4-20250514"

# Convex
CONVEX_DEPLOYMENT_URL="https://your-project.convex.cloud"
CONVEX_ACCESS_KEY="your-convex-access-key"

# Meta Ads API
META_ACCESS_TOKEN="EAAxxx..."
META_APP_ID="123456789"
META_APP_SECRET="abc123def456"

# Google Ads API
GOOGLE_ACCESS_TOKEN="ya29xxx..."
GOOGLE_CLIENT_ID="123456789-xxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxx..."

# Shopify
SHOPIFY_STORE_DOMAIN="your-store.myshopify.com"
SHOPIFY_ACCESS_TOKEN="shpat_xxx..."

# Google Analytics 4 (GA4)
GA4_PROPERTY_ID="123456789"

# Klaviyo
KLAVIYO_API_KEY="pk_xxx..."

# Resend Email
RESEND_API_KEY="re_xxx..."
RESEND_FROM_ADDRESS="ai-agent@yourdomain.com"

# Optional
LOG_LEVEL="INFO"
